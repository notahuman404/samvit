(kicad_pcb
  (version 20230121)
  (generator "samvit-hardware-agent")
  (general
    (thickness 1.60)
  )
  (paper "A4")
  (title_block
    (title "that takes in live depth data from two sensors, builds a spa")
    (rev "v13.0")
    (company "Samvit AI Pipeline")
  )
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (44 "Edge.Cuts" user)
  )
  (setup
    (pad_to_mask_clearance 0.051)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (outputdirectory "gerbers/")
    )
  )
  (gr_rect (start 0 0) (end 100.00 80.00) (layer "Edge.Cuts") (width 0.05))
)
