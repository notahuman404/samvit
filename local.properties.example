## This file is NOT committed to source control.
## Copy to local.properties and fill in your keys.
## Get a free Gemini API key at: https://aistudio.google.com/app/apikey

sdk.dir=/path/to/your/Android/Sdk
GEMINI_API_KEY=your_gemini_api_key_here

## Gap 9 — Backend / Android integration
## URL of the Samvit FastAPI backend.  For the Android emulator use 10.0.2.2 to
## reach the host machine.  For a real device on the same Wi-Fi, use the host IP.
## Leave blank to disable backend routing and use on-device Gemini exclusively.
BACKEND_URL=http://10.0.2.2:8000

## Set to true to route complex multi-step intents to POST /agent/plan instead
## of calling Gemini directly on-device.  Requires BACKEND_URL to be set.
USE_BACKEND_AGENT=false

## Gap 7 — Porcupine wake-word engine
## Obtain a free AccessKey at https://console.picovoice.ai/
## Also add your keyword model (samvit_android.ppn) to app/src/main/assets/
PORCUPINE_ACCESS_KEY=

## ── Demo / filming mode ─────────────────────────────────────────────────────
## Set to true to enable scripted responses for filming a demo without a live
## backend or Gemini API key.  The orb, state transitions, and UI behave exactly
## as in production — only the AI call is replaced with a scripted sequence.
##
## NEVER ship a release build with DEMO_MODE=true.
##
## Commands recognised in demo mode (say naturally — matching is loose):
##   "Find me a hospital near Gandhi Path, Jaipur"  → hospital search + results
##   "Find and call the nearest clinic"             → clinic search + call
##   "Open Chrome / search for / browse"            → multi-step narration (say
##                                                    "Stop" to halt mid-flow)
##   "What is / tell me about / explain"            → spoken web search result
##
## All other utterances (Stop, Emergency, Mayday) still work normally via the
## DeterministicMatcher — no demo key required for those.
DEMO_MODE=false
