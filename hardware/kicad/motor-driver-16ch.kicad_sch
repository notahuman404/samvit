  (text "PCA9685 16-Channel PWM Controller\nI2C address configured by solder jumpers A0-A5.\nBoards PCA1-PCA9 use addresses 0x40-0x48.\nPRE_SCALE register = 0x1E for 200Hz PWM frequency.\nAll 16 LED outputs connect to gate resistors of AO3400A MOSFETs.\nSee motor-driver-cell.kicad_sch for single-cell detail."
    (at 170 20 0)
    (effects
      (font (size 1.27 1.27))
      (justify left)
    )
    (uuid "aa100001-0000-0000-0000-000000000001")
  )

  (text "Address Jumpers (A0-A5 to GND=0, to VCC=1):\n  0x40: A0=0 A1=0 A2=0 A3=0 A4=0 A5=0\n  0x41: A0=1 A1=0 A2=0 A3=0 A4=0 A5=0\n  0x42: A0=0 A1=1 A2=0 A3=0 A4=0 A5=0\n  0x43: A0=1 A1=1 A2=0 A3=0 A4=0 A5=0\n  0x44: A0=0 A1=0 A2=1 A3=0 A4=0 A5=0\n  0x45: A0=1 A1=0 A2=1 A3=0 A4=0 A5=0\n  0x46: A0=0 A1=1 A2=1 A3=0 A4=0 A5=0\n  0x47: A0=1 A1=1 A2=1 A3=0 A4=0 A5=0\n  0x48: A0=0 A1=0 A2=0 A3=1 A4=0 A5=0"
    (at 170 45 0)
    (effects
      (font (size 1.27 1.27))
      (justify left)
    )
    (uuid "aa100001-0000-0000-0000-000000000002")
  )

