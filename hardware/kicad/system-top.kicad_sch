  (text "SYSTEM ARCHITECTURE — HAPTIC VEST"
    (at 130 10 0)
    (effects (font (size 3.0 3.0) (bold yes)) (justify center))
    (uuid "tt000001-0000-0000-0000-000000000001")
  )

  (text "Pipeline:\nD435i depth frame (848x480 @ 90fps, ~11ms) →\nUSB3 to Pi (~1.5ms) → depth resize+map (~2ms) →\nI2C write 9x PCA9685 (~9ms) → AO3400A gate (~0.1ms) →\nERM motor spin-up (~15ms)\nTotal: ~38ms  Target: <50ms ✓"
    (at 250 20 0)
    (effects (font (size 1.5 1.5)) (justify left))
    (uuid "tt000001-0000-0000-0000-000000000002")
  )

  (text "Power Budget:\n  Pi 4B:         6W  @ 5V\n  D435i x2:      3W  @ 5V (USB)\n  Motors 144x: 5.2W  @ 3V (avg 30%)\n  Audio:         1W  @ 5V\n  PCA9685 x9:   <1W  @ 5V\n  ─────────────────\n  TOTAL avg:   ~16W\n  TOTAL peak:  ~31W\n  Battery: 65W PD bank, 26800mAh\n  Runtime: ~4-5 hours"
    (at 250 55 0)
    (effects (font (size 1.5 1.5)) (justify left))
    (uuid "tt000001-0000-0000-0000-000000000003")
  )

  (text "I2C Bus: 400kHz fast-mode\nPull-ups: 4.7kΩ to 3.3V\n(in addition to Pi internal ~1.8kΩ)\n\nPCA9685 addresses:\n  PCA1: 0x40   PCA6: 0x45\n  PCA2: 0x41   PCA7: 0x46\n  PCA3: 0x42   PCA8: 0x47\n  PCA4: 0x43   PCA9: 0x48\n  PCA5: 0x44\n\nALL_CALL: 0x70 (broadcast)"
    (at 250 100 0)
    (effects (font (size 1.5 1.5)) (justify left))
    (uuid "tt000001-0000-0000-0000-000000000004")
  )

  (text "Motor Grid: 12x12 = 144 motors\n35mm center-to-center spacing\n420mm x 420mm total grid area\nM001 = top-left (Row1, Col1)\nM144 = bottom-right (Row12, Col12)\nmotor_idx = row*12 + col  (0-based)"
    (at 250 145 0)
    (effects (font (size 1.5 1.5)) (justify left))
    (uuid "tt000001-0000-0000-0000-000000000005")
  )

